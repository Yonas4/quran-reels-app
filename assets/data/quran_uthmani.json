[
  {
    "number": 1,
    "name": "الفاتحة",
    "englishName": "",
    "englishNameTranslation": "",
    "numberOfAyahs": 7,
    "revelationType": "Meccan",
    "ayahs": [
      {
        "number": 1,
        "numberInSurah": 1,
        "text": "بِسْمِ ٱللَّهِ ٱلرَّحۡمَـٰنِ ٱلرَّحِيمِ",
        "juz": 1,
        "page": 1
      },
      {
        "number": 778,
        "numberInSurah": 2,
        "text": "ٱلۡحَمۡدُ لِلَّهِ رَبِّ ٱلۡعَـٰلَمِينَ",
        "juz": 1,
        "page": 1
      },
      {
        "number": 779,
        "numberInSurah": 3,
        "text": "ٱلرَّحۡمَـٰنِ ٱلرَّحِيمِ",
        "juz": 1,
        "page": 1
      },
      {
        "number": 780,
        "numberInSurah": 4,
        "text": "مَـٰلِكِ يَوۡمِ ٱلدِّينِ",
        "juz": 1,
        "page": 1
      },
      {
        "number": 781,
        "numberInSurah": 5,
        "text": "إِيَّاكَ نَعۡبُدُ وَإِيَّاكَ نَسۡتَعِينُ",
        "juz": 1,
        "page": 1
      },
      {
        "number": 782,
        "numberInSurah": 6,
        "text": "ٱهۡدِنَا ٱلصِّرَٰطَ ٱلۡمُسۡتَقِيمَ",
        "juz": 1,
        "page": 1
      },
      {
        "number": 783,
        "numberInSurah": 7,
        "text": "صِرَٰطَ ٱلَّذِينَ أَنۡعَمۡتَ عَلَيۡهِمۡ غَيۡرِ ٱلۡمَغۡضُوبِ عَلَيۡهِمۡ وَلَا ٱلضَّآلِّينَ",
        "juz": 1,
        "page": 1
      }
    ]
  },
